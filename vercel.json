{
  "headers": [
    {
      "source": "/auth/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://loghue.com"
        },
        { "key": "Access-Control-Allow-Methods", "value": "GET" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://loghue.com"
        },
        { "key": "Access-Control-Allow-Methods", "value": "GET" }
      ]
    }
  ]
}
